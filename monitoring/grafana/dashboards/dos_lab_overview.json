{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "DoS Lab — Real-time attack monitoring with resource-limited victim",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "🚨 DoS Lab — Live Attack Monitor",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "#EAB839", "value": 20},
              {"color": "orange", "value": 50},
              {"color": "red", "value": 100}
            ]
          },
          "unit": "reqps",
          "mappings": []
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 1},
      "id": 1,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "value_and_name", "colorMode": "background"},
      "title": "⚡ Request Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(apache_accesses_total[15s])",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "#EAB839", "value": 5},
              {"color": "orange", "value": 8},
              {"color": "red", "value": 10}
            ]
          },
          "unit": "short",
          "max": 10,
          "min": 0
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 1},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "value_and_name", "colorMode": "background"},
      "title": "👷 Busy Workers (max 10)",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "apache_workers{state=\"busy\"}",
          "legendFormat": "busy / 10",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "#EAB839", "value": 50},
              {"color": "orange", "value": 200},
              {"color": "red", "value": 1000}
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 1},
      "id": 4,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "value_and_name", "colorMode": "background"},
      "title": "⏱️ Avg Response Time",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(apache_duration_ms_total[15s]) / rate(apache_accesses_total[15s])",
          "legendFormat": "ms",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 1},
      "id": 3,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "value_and_name", "colorMode": "background"},
      "title": "🔌 Active Connections",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "apache_connections{state=\"total\"}",
          "legendFormat": "connections",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 25, "gradientMode": "scheme", "showPoints": "never", "spanNulls": true},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 6},
      "id": 10,
      "options": {"tooltip": {"mode": "multi"}},
      "title": "📈 Request Rate Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(apache_accesses_total[15s])",
          "legendFormat": "requests/sec",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 20, "gradientMode": "scheme", "showPoints": "never", "spanNulls": true},
          "unit": "short",
          "max": 12,
          "min": 0
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "🔴 busy"},
            "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]
          },
          {
            "matcher": {"id": "byName", "options": "🟢 idle"},
            "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]
          }
        ]
      },
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 6},
      "id": 11,
      "options": {"tooltip": {"mode": "multi"}},
      "title": "👷 Workers — Busy (red) vs Idle (green) — MAX 10",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "apache_workers{state=\"busy\"}",
          "legendFormat": "🔴 busy",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "apache_workers{state=\"idle\"}",
          "legendFormat": "🟢 idle",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 15, "gradientMode": "scheme", "showPoints": "never", "spanNulls": true},
          "unit": "ms"
        }
      },
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 15},
      "id": 13,
      "options": {"tooltip": {"mode": "multi"}},
      "title": "⏱️ Response Time (ms) — Spikes = Server Struggling",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(apache_duration_ms_total[15s]) / rate(apache_accesses_total[15s])",
          "legendFormat": "avg response time",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 15, "gradientMode": "scheme", "showPoints": "never", "spanNulls": true},
          "unit": "KBs"
        }
      },
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 15},
      "id": 12,
      "options": {"tooltip": {"mode": "multi"}},
      "title": "📊 Apache Throughput (KB/sec)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(apache_sent_kilobytes_total[15s])",
          "legendFormat": "KB/sec sent",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24},
      "id": 14,
      "options": {"tooltip": {"mode": "multi"}},
      "title": "🔌 Apache Connection States",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "apache_connections{state=\"total\"}",
          "legendFormat": "total connections",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "apache_connections{state=\"keepalive\"}",
          "legendFormat": "keepalive",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "apache_connections{state=\"closing\"}",
          "legendFormat": "closing",
          "refId": "C"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "apache_connections{state=\"writing\"}",
          "legendFormat": "writing",
          "refId": "D"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["dos-lab", "security", "monitoring"],
  "templating": {"list": []},
  "time": {"from": "now-15m", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "DoS Lab — Overview Dashboard",
  "uid": "dos-lab-overview",
  "version": 3
}
