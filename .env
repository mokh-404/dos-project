# ============================================================
# DoS Attack Simulation Lab — Environment Configuration
# ============================================================

# ── Victim Server ────────────────────────────────────────────
VICTIM_PORT=8080
APACHE_LOG_LEVEL=warn

# ── Attack Parameters ────────────────────────────────────────
ATTACK_RATE=200
ATTACK_DURATION=30
ATTACK_CONCURRENCY=50

# ── Monitoring ───────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=doslab2024

# ── Mitigation ───────────────────────────────────────────────
MITIGATION_PORT=8443

# ── Packet Capture ───────────────────────────────────────────
CAPTURE_INTERFACE=eth0
CAPTURE_FILTER=tcp port 80
CAPTURE_ROTATE_SECONDS=60
